# MCAT free-response AI grader — environment template.
#
# Copy this file to .env.local and fill in your key:
#     cp .env.example .env.local
# .env.local is git-ignored (never committed). Both `./run` (the in-app grader in
# rslib/src/backend/mcat.rs) and the eval harness (tools/eval_grader.py) load it.

# Required to grade free-response questions and to run the eval harness.
OPENAI_API_KEY=

# Optional overrides ---------------------------------------------------------
# Model the in-app FRQ grader uses (default: gpt-4o-mini).
OPENAI_GRADER_MODEL=gpt-4o-mini
# Model the eval harness uses (default: gpt-4o-mini).
OPENAI_EVAL_MODEL=gpt-4o-mini
# Alternate OpenAI-compatible chat-completions endpoint (default:
# https://api.openai.com/v1/chat/completions). Handy for a local mock in tests.
# OPENAI_BASE_URL=
